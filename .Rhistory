library(tidyverse)
rm( list=ls() )
data <- read_csv("Z:/DataStrategy/RecSys_file_automation/mobiz_backups/Recommender_Data")
relational <- read_csv("Z:/DataStrategy/RecSys_file_automation/mobiz_backups/Recommender_Relational")
occ_products <- read_csv("Z:/DataStrategy/RecSys_file_automation/mobiz_backups/OCC_Products_Table")
nrow(occ_products)
length(unique(occ_products$repositoryId))
nrow(data)
length(unique(data$PersonNo))
length(unique(relational$PersonNo))
# number of unique products per person:
relational %>%
group_by(PersonNo) %>%
summarise( n_unique_ItemNo = n_distinct(ItemNo) ) %>%
group_by( n_unique_ItemNo ) %>%
summarise( n = n() )
# are there any missing products?
PersonNo_with_a_missing_product <-
relational %>%
left_join(
occ_products %>% rename(ItemNo=repositoryId),
by = "ItemNo"
) %>%
filter( is.na(product_route) ) %>%
distinct( PersonNo )
nrow(PersonNo_with_a_missing_product)
occ_products %>% summarise( nrows=n(), n_distinct_ItemNo=n_distinct(repositoryId) )
