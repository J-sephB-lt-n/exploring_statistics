n_sims <- 500
store_yd <- rep(NA,n_sims)
for( i in 1:n_sims ){
print(i)
people$treatment <- sample( c(rep("E",n/2),rep("C",n/2)) )
people <-
people %>%
mutate( y = ifelse(treatment=="E",E,C) )
store_yd[i] <- mean(people$y[people$treatment=="E"]) - mean(people$y[people$treatment=="C"])
}
hist( store_yd )
abline( v = tau, col=2 )
mean(store_yd)
hist( store_yd, breaks=50 )
