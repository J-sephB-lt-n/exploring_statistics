test <- tibble( x = c(1, 1, 2, 3,  6, 4, 8, 7 ),
y = c(1, 4, 2, 2,  8,  4, 4, 6 ),
cluster = c(2,2, 2, 2, 3, 3, 3, 3)
)
plot( test$y ~ test$x,
pch=16,
xlim = c(0,10),
ylim = c(0,10),
col = test$cluster,
cex = 2,
main = sum( as.matrix( dist(test,method="euclidean") )[3,][1:4] ) +
sum( as.matrix( dist(test,method="euclidean") )[8,][5:8] )
)
segments( x0 = rep(2, 3),
y0 = rep(2, 3),
x1 = test$x[c(1,2,4)],
y1 = test$y[c(1,2,4)],
lty = 3
)
segments( x0 = rep(7, 4),
y0 = rep(6, 4),
x1 = test$x[5:7],
y1 = test$y[5:7],
lty = 3
)
