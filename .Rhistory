k <- length(population_probs)
n_sims <- 100
run_sims <-
rmultinom(      n = n_sims,
size = n_samplesize,
prob = population_probs
) %>%
t()
rownames(run_sims) <- paste( "sim", 1:n_sims, sep="" )
run_sims_proportions <- run_sims / n_samplesize
head( run_sims )
head( run_sims_proportions )
store_results <- list()
?MultinomCI
store_results <- list()
ci_method <- "sisonglaz"
conf_level <- 0.9
get_intervals <-
lapply(   X = 1:n_sims,
function(i){ DescTools::MultinomCI(          x = run_sims[i,],
conf.level = conf_level,
sides = "two.sided",
method = ci_method
)
}
)
lower_ci <- lapply( get_intervals,
function(x){ t(x[,"lwr.ci"]) }
) %>%
reduce( rbind )
upper_ci <- lapply( get_intervals,
function(x){ t(x[,"upr.ci"]) }
) %>%
reduce( rbind )
contains_parameters_lower <-
apply(   X = lower_ci,
MAR = 1,
FUN = function(x){ x <= population_probs }
) %>%
apply(   X = .,
MAR = 2,
FUN = function(x){ sum(x==FALSE) == 0 }
)
contains_parameters_upper <-
apply(   X = upper_ci,
MAR = 1,
FUN = function(x){ x >= population_probs }
) %>%
apply(   X = .,
MAR = 2,
FUN = function(x){ sum(x==FALSE) == 0 }
)
contains_parameters <- contains_parameters_lower & contains_parameters_upper
proportion_correct <- sum(contains_parameters) / n_sims
proportion_correct
interval_widths <- upper_ci - lower_ci
interval_widths
proportion_correct
