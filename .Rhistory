par(pty="s")
sileg <- tibble(       x = c( 1, 2, 1, 4, 3,   8, 8, 9),
y = c( 3, 1, 7, 5, 9,   11, 8, 9),
cluster = c( 2, 2, 2, 2, 2,   3,  3, 3)
)
plot( sileg$y ~ sileg$x,
xlim=c(0,12),
ylim=c(0,12),
axes=FALSE,
col=sileg$cluster,
pch=16,
cex=1.5,
xlab="x", ylab="y"
)
axis( side=1, at=0:15 )
axis( side=2, at=0:15, las=1 )
par(pty="s")
plot( sileg$y ~ sileg$x,
xlim=c(0,12),
ylim=c(0,12),
axes=FALSE,
col=sileg$cluster,
pch=16,
cex=1.5,
xlab="x", ylab="y"
)
axis( side=1, at=0:15 )
axis( side=2, at=0:15, las=1 )
arrows( x0=10, y0=3, x1=8, y1=8 )
par(pty="s")
get_dist <- dist( sileg[6:8,c("x","y")], method="euclidean" ) %>% as.matrix()
plot( sileg$y ~ sileg$x,
xlim=c(0,12),
ylim=c(0,12),
axes=FALSE,
col=sileg$cluster,
pch=16,
cex=1.5,
xlab="x", ylab="y"
)
axis( side=1, at=0:15 )
axis( side=2, at=0:15, las=1 )
segments( x0 = c(sileg$x[7],sileg$x[7]),
y0 = c(sileg$y[7],sileg$y[7]),
x1 = c(sileg$x[6],sileg$x[8]),
y1 = c(sileg$y[6],sileg$y[8]),
lty = 2
)
text( x = 7.5, y=10, labels=get_dist[2,1] )
text( x = 9, y=8, labels= get_dist[2,3], adj=-0.001 )
par(pty="s")
get_dist <- dist( sileg[c(1:5,7),c("x","y")], method="euclidean" ) %>% as.matrix()
plot( sileg$y ~ sileg$x,
xlim=c(0,12),
ylim=c(0,12),
axes=FALSE,
col=sileg$cluster,
pch=16,
cex=1.5,
xlab="x", ylab="y"
)
axis( side=1, at=0:15 )
axis( side=2, at=0:15, las=1 )
segments( x0 = rep( sileg$x[7], 5 ),
y0 = rep( sileg$x[7], 5 ),
x1 = sileg$x[1:5],
y1 = sileg$y[1:5],
lty = 2
)
text( x =         c(2, 5, 3, 5, 5),
y =         c(4, 3, 7, 6, 9),
labels = c( round(get_dist[6,1], 6),
round(get_dist[6,2], 6),
round(get_dist[6,3], 6),
get_dist[6,4],
round(get_dist[6,5], 6)
)
)
get_silhouettes <-
cluster::silhouette( sileg$cluster,
dist = dist(sileg[,c("x","y")], method="euclidean")
)
par(pty="s")
plot( sileg$y ~ sileg$x,
xlim=c(0,12),
ylim=c(0,12),
axes=FALSE,
col=sileg$cluster,
pch=16,
cex=1.5,
xlab="x", ylab="y"
)
axis( side=1, at=0:15 )
axis( side=2, at=0:15, las=1 )
text( x = sileg$x,
y = sileg$y,
labels = round( get_silhouettes[,"sil_width"], 3),
pos = 3
)
