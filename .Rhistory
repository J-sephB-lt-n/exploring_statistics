n <- 1e6L
people <-
tibble( C = sample(0:100, size=n, replace=TRUE) ) %>%
mutate( E = C + rnorm(n=n(), mean=2, sd=1) )
people
people <-
tibble( id = 1:n,
C = sample(0:100, size=n, replace=TRUE)
) %>%
mutate( E = C + rnorm(n=n(), mean=2, sd=1) )
people
n+(1:n)
people <- bind_rows( people,
people %>%
mutate( id = n+(1:n) )
)
