plot_fitted_model_ftn <- function( model_object, plot_title="", df, degree, ns=FALSE ){
par(bg="black", col="white", col.axis="white", col.lab="white", col.main="white")
n_knots <- df - degree
if( ns == TRUE ){ n_knots <- df - 1 }
knots_at <- quantile( random_data$x, probs=seq(0,1,length.out=n_knots+2) )
knots_at <- knots_at[-c(1,length(knots_at))]   # remove 1st and last entry in "knots_at"
plot(    x = random_data$x,
y = random_data$y,
xlab = "x",
ylab = "y",
pch = 16,
main = plot_title,
xlim = c( min(random_data$x)-20, max(random_data$x)+20 )
)
x_seq <- seq( min(random_data$x)-30, max(random_data$x)+30, length.out=1000  )
model_fitted_values <- predict( model_object, newdata = tibble(x=x_seq) )
lines( x = x_seq,
y = model_fitted_values,
col = 2
)
abline( v = knots_at, lty=2 )
if( ns==TRUE ){ abline( v = c( min(random_data$x), max(random_data$x) ) ) }
}
lm_ns_df6 <- lm( y ~ ns(x, df = 6 ),
data = random_data
)
plot_fitted_model_ftn( lm_ns_df6, "natural splines, df=6, degree=3", df=6, degree=3, ns=TRUE )
coef(lm_ns_df6)
lm_ns_df5 <- lm( y ~ ns(x, df = 5 ),
data = random_data
)
plot_fitted_model_ftn( lm_ns_df5, "natural splines, df=5, degree=3", df=5, degree=3, ns=TRUE )
coef(lm_ns_df5)
library(tidyverse)
setwd("~/exploring_statistics/exploring_statistics/")
rmarkdown::render_site()
google_analytics_global_site_tag <-
"
<!-- Global site tag (gtag.js) - Google Analytics -->
<script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-163824605-1\"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'UA-163824605-1');
</script>
"
for( file_i in c("index.html", "about.html", "future_content.html") ){
cat("processing [[", file_i, "]]...\n" )
readin_html_text <- readr::read_lines(file_i)
line_to_insert_google_analytics_global_site_tag_code <-
min( grep('<head>', readin_html_text) ) +1
complete_html <-
paste0(
# html before google analytics global site tag code:
paste( readin_html_text[1:(line_to_insert_google_analytics_global_site_tag_code-1)],
collapse="\n"
)
,
# google analytics global site tag code:
google_analytics_global_site_tag
,
# html after google analytics global site tag code:
paste( readin_html_text[line_to_insert_google_analytics_global_site_tag_code:length(readin_html_text)],
collapse="\n"
)
)
readr::write_lines(    x = complete_html,
path = file_i
)
}
