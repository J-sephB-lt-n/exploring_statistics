data = random_data
)
coef(fit_lm_poly3)
model_fitted_values <- predict( fit_lm_poly3, newdata = tibble(x=x_seq) )
par(bg="black", col="white", col.axis="white", col.lab="white", col.main="white")
plot(    x = random_data$x,
