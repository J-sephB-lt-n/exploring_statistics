sum( as.matrix( dist(test,method="euclidean") )[8,][c(5,7)] )
)
segments( x0 = rep(2, 4),
y0 = rep(2, 4),
x1 = test$x[c(1,2,4,6)],
y1 = test$y[c(1,2,4,6)],
lty = 3
)
segments( x0 = rep(7, 2),
